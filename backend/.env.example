# Caption Studio Backend - Environment Variables Configuration Template
# Place direct credential secrets inside .env at this directory level (DO NOT COMMIT THE ACTUAL .env FILE)

# Server Configuration Options
PORT=10000
FRONTEND_URL=https://your-frontend-vercel-domain.vercel.app

# Whisper API Provider Settings (Local model or Endpoint)
WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
WHISPER_API_KEY=your_whisper_api_key_goes_here
WHISPER_MODEL=whisper-1

# Optional Advanced Control Settings
# Maximum duration to wait for transcription API responses (in milliseconds)
WHISPER_TIMEOUT=60000
# Maximum retry attempts for transient API drops
WHISPER_MAX_RETRIES=3
# Keep audio/video processing intermediate files for diagnostic debugging (true | false)
KEEP_TEMP_FILES=false
